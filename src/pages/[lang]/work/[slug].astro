---
import Base from '../../../layouts/Base.astro';
import { site } from '../../../data/site.js';
import projects from '../../../data/projects.json';
import { synopses } from '../../../i18n/synopses.js';
import { awards } from '../../../i18n/awards.js';
import { locales, useTranslations } from '../../../i18n/ui.js';

export function getStaticPaths() {
  const paths = [];
  for (const lang of locales) {
    projects.forEach((project, i) => {
      const next = projects[(i + 1) % projects.length];
      paths.push({ params: { lang, slug: project.slug }, props: { project, next } });
    });
  }
  return paths;
}

const { lang } = Astro.params;
const { project, next } = Astro.props;
const t = useTranslations(lang);

const category = t(`cat.${project.category}`);
const status = /^\d{4}$/.test(project.status) ? project.status : t(`status.${project.status}`);
const synopsis = synopses[project.slug]?.[lang] || synopses[project.slug]?.en || '';
const award = awards[project.slug]?.[lang] || awards[project.slug]?.en || '';
const metaDesc = synopsis.replace(/^["“”]|["“”]$/g, '').slice(0, 155);

// --- structured-data helpers (from credits) ---
const creditMap = Object.fromEntries(project.credits);
const persons = (val) =>
  val ? val.split(',').map((n) => ({ '@type': 'Person', name: n.trim() })).filter((p) => p.name) : undefined;
const orgs = (val) =>
  val ? val.split(',').map((n) => ({ '@type': 'Organization', name: n.trim() })).filter((o) => o.name) : undefined;

const isoDate = (() => {
  const rd = creditMap.releaseDate;
  if (rd) {
    const d = new Date(rd);
    if (!isNaN(d.getTime())) return d.toISOString().slice(0, 10);
  }
  return /^\d{4}$/.test(project.status) ? `${project.status}-01-01` : undefined;
})();
const isoDuration = (() => {
  const rt = creditMap.runtime;
  const m = rt && (rt.match(/(\d+)\s*(?:'|min)/i) || rt.match(/^(\d+)/));
  return m ? `PT${m[1]}M` : undefined;
})();

const imageAbs = new URL(project.image, site.url).href;
const thumbAbs = new URL(project.thumb, site.url).href;
const logoAbs = new URL('/images/logo.png', site.url).href;
const publisher = { '@type': 'Organization', name: site.legalName, logo: { '@type': 'ImageObject', url: logoAbs } };

const workNode = {
  '@type': project.category === 'Doc' ? 'Movie' : 'CreativeWork',
  name: project.title,
  genre: category,
  description: synopsis,
  image: imageAbs,
  inLanguage: lang,
  url: `${site.url}/${lang}/work/${project.slug}/`,
  productionCompany: orgs(creditMap.producedBy) || { '@type': 'Organization', name: site.legalName },
  ...(persons(creditMap.directedBy) ? { director: persons(creditMap.directedBy) } : {}),
  ...(persons(creditMap.starring) ? { actor: persons(creditMap.starring) } : {}),
  ...(persons(creditMap.writtenBy) ? { author: persons(creditMap.writtenBy) } : {}),
  ...(isoDate ? { datePublished: isoDate } : {}),
  ...(isoDuration ? { duration: isoDuration } : {}),
  ...(award ? { award } : {}),
};

const videoNode = project.video
  ? {
      '@type': 'VideoObject',
      name: `${project.title} — Trailer`,
      description: synopsis || `${project.title} trailer`,
      thumbnailUrl: [thumbAbs],
      ...(isoDate ? { uploadDate: isoDate } : {}),
      embedUrl:
        project.video.provider === 'youtube'
          ? `https://www.youtube.com/embed/${project.video.id}`
          : `https://player.vimeo.com/video/${project.video.id}`,
      contentUrl:
        project.video.provider === 'youtube'
          ? `https://www.youtube.com/watch?v=${project.video.id}`
          : `https://vimeo.com/${project.video.id}`,
      publisher,
    }
  : null;

const breadcrumb = {
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: t('nav.work'), item: `${site.url}/${lang}/` },
    { '@type': 'ListItem', position: 2, name: project.title, item: `${site.url}/${lang}/work/${project.slug}/` },
  ],
};

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [workNode, ...(videoNode ? [videoNode] : []), breadcrumb],
};
---

<Base
  locale={lang}
  title={project.title}
  description={metaDesc}
  image={project.thumb}
  type="article"
  jsonLd={jsonLd}
  subpath={`work/${project.slug}`}
>
  <article class="post">
    <div class="padding-global">
      <div class="post-inner">
        <a href={`/${lang}/#work`} class="back caps">← {t('project.back')}</a>

        <div class="post-grid">
          <div class="post-poster">
            <img
              src={project.image}
              srcset={project.imageSrcset}
              sizes="(max-width: 820px) 80vw, 40vw"
              alt={project.title}
              width={project.imageW}
              height={project.imageH}
              loading="eager"
              decoding="async"
            />
          </div>

          <div class="post-info">
            <h1 class="post-title caps">{project.title}</h1>
            <div class="post-tags">
              <span class="tag caps">{category}</span>
              <span class="tag caps">{status}</span>
            </div>

            {
              project.credits.length > 0 && (
                <dl class="credits">
                  {project.credits.map(([labelKey, value]) => (
                    <div class="credit-row">
                      <dt class="caps">{t(`credit.${labelKey}`)}</dt>
                      <dd>{value}</dd>
                    </div>
                  ))}
                </dl>
              )
            }

            <div class="post-synopsis">
              <p>{synopsis}</p>
              {
                award && (
                  <p class="award">
                    <span class="award-icon" aria-hidden="true">🏆</span>
                    <span>{award}</span>
                  </p>
                )
              }
            </div>
          </div>
        </div>

        {
          project.video && (
            <div class="post-video video" data-provider={project.video.provider} data-id={project.video.id}>
              <button type="button" class="video-play" aria-label="Play trailer">
                <img src={project.thumb} srcset={project.thumbSrcset} sizes="(max-width: 768px) 100vw, 72rem" alt="" width={project.thumbW} height={project.thumbH} loading="lazy" decoding="async" />
                <span class="video-btn" aria-hidden="true" />
              </button>
            </div>
          )
        }

        <a href={`/${lang}/work/${next.slug}`} class="next-project">
          <span class="caps next-label">{t('project.next')}</span>
          <span class="next-title caps">{next.title} →</span>
        </a>
      </div>
    </div>
  </article>

  <script is:inline>
    document.querySelectorAll('.video[data-id]').forEach(function (el) {
      var btn = el.querySelector('.video-play');
      if (!btn) return;
      btn.addEventListener('click', function () {
        var provider = el.getAttribute('data-provider');
        var id = el.getAttribute('data-id');
        var src =
          provider === 'youtube'
            ? 'https://www.youtube-nocookie.com/embed/' + id + '?autoplay=1&rel=0'
            : 'https://player.vimeo.com/video/' + id + '?autoplay=1&title=0&byline=0&portrait=0&dnt=1';
        var f = document.createElement('iframe');
        f.src = src;
        f.allow = 'autoplay; fullscreen; picture-in-picture; encrypted-media';
        f.setAttribute('allowfullscreen', '');
        f.setAttribute('title', 'Trailer');
        f.style.cssText = 'width:100%;height:100%;border:0;display:block';
        el.innerHTML = '';
        el.appendChild(f);
      });
    });
  </script>
</Base>

<style>
  .post {
    padding-top: clamp(6.5rem, 14vh, 10rem);
  }
  .post-inner {
    max-width: 72rem;
    margin-inline: auto;
  }
  .back {
    display: inline-block;
    font-size: 0.82rem;
    letter-spacing: 0.08em;
    color: var(--grey);
    margin-bottom: 2.5rem;
    transition: color 0.2s var(--ease);
  }
  .back:hover {
    color: var(--white);
  }

  /* Two-column: poster left, info right (like the original) */
  .post-grid {
    display: grid;
    grid-template-columns: 1fr 1.3fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: start;
  }
  .post-poster img {
    width: 100%;
    height: auto;
    border-radius: 12px;
    background: var(--surface);
  }

  .post-title {
    font-weight: 700;
    font-size: clamp(1.9rem, 4vw, 3rem);
    letter-spacing: -0.01em;
    line-height: 1.05;
  }
  .post-tags {
    display: flex;
    gap: 0.6rem;
    margin-top: 1.1rem;
  }
  .tag {
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    padding: 0.35rem 0.75rem;
    border: 1px solid var(--line);
    border-radius: 100px;
    color: rgba(251, 251, 251, 0.85);
  }

  .credits {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.4rem 1.5rem;
    margin-top: 2.25rem;
    padding-top: 2.25rem;
    border-top: 1px dashed var(--line);
  }
  .credit-row {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .credit-row dt {
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    color: #b4b4b4;
  }
  .credit-row dd {
    margin: 0;
    font-size: 1.02rem;
    font-weight: 500;
    line-height: 1.4;
    color: var(--white);
  }

  .post-synopsis {
    margin-top: 2.25rem;
    padding-top: 2.25rem;
    border-top: 1px dashed var(--line);
  }
  .post-synopsis p {
    font-size: clamp(1.02rem, 1.4vw, 1.15rem);
    line-height: 1.65;
    color: rgba(251, 251, 251, 0.9);
  }
  .award {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    margin-top: 1.5rem;
    padding: 0.9rem 1.1rem;
    border: 1px solid rgba(204, 65, 70, 0.4);
    border-radius: 10px;
    background: rgba(204, 65, 70, 0.08);
    font-size: 0.95rem;
    line-height: 1.5;
    color: var(--white);
  }
  .award-icon {
    flex-shrink: 0;
    font-size: 1.05rem;
    line-height: 1.4;
  }

  /* Full-width trailer below (like the original) */
  .post-video {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    margin-top: clamp(3rem, 7vw, 5rem);
    border-radius: 12px;
    overflow: hidden;
    background: var(--surface);
  }
  .video-play {
    display: block;
    width: 100%;
    height: 100%;
    padding: 0;
    border: 0;
    background: none;
    cursor: pointer;
  }
  .video-play img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: filter 0.3s var(--ease);
  }
  .video-play:hover img {
    filter: brightness(0.85);
  }
  .video-btn {
    position: absolute;
    inset: 0;
    margin: auto;
    width: 82px;
    height: 82px;
    border-radius: 50%;
    background: rgba(0, 0, 0, 0.5);
    border: 2px solid rgba(255, 255, 255, 0.9);
    transition: background 0.25s var(--ease), transform 0.25s var(--ease);
  }
  .video-btn::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 54%;
    transform: translate(-50%, -50%);
    border-style: solid;
    border-width: 12px 0 12px 20px;
    border-color: transparent transparent transparent #fff;
  }
  .video-play:hover .video-btn {
    background: var(--red);
    border-color: var(--red);
    transform: scale(1.06);
  }
  .video-iframe {
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
  }

  .next-project {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-top: clamp(4rem, 9vw, 6rem);
    padding-top: 2.5rem;
    border-top: 1px dashed var(--line);
  }
  .next-label {
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    color: var(--grey);
  }
  .next-title {
    font-weight: 700;
    font-size: clamp(1.5rem, 3.5vw, 2.4rem);
    text-decoration: underline;
    text-decoration-color: transparent;
    text-underline-offset: 4px;
    text-decoration-thickness: 2px;
    transition: text-decoration-color 0.3s var(--ease);
  }
  .next-project:hover .next-title {
    text-decoration-color: currentColor;
  }

  @media (max-width: 820px) {
    .post-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .post-poster {
      max-width: 22rem;
    }
    .credits {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 480px) {
    .credits {
      grid-template-columns: 1fr;
    }
    .video-btn {
      width: 62px;
      height: 62px;
    }
  }
</style>
