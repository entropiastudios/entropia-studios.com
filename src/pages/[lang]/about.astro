---
import Base from '../../layouts/Base.astro';
import { site } from '../../data/site.js';
import { locales, useTranslations } from '../../i18n/ui.js';
import { about } from '../../i18n/about.js';

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = useTranslations(lang);
const a = about[lang] || about.en;

const orgNode = {
  '@type': 'Organization',
  name: site.legalName,
  alternateName: site.name,
  url: `${site.url}/${lang}/`,
  logo: new URL('/images/logo.png', site.url).href,
  email: site.email,
  ...(site.socials?.length ? { sameAs: site.socials.map((s) => s.url) } : {}),
  address: site.offices.map((o) => ({
    '@type': 'PostalAddress',
    name: o.name,
    streetAddress: o.street,
    addressLocality: o.city,
    addressCountry: o.country,
  })),
};
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    { '@type': 'AboutPage', name: `${a.heading} — ${site.name}`, url: `${site.url}/${lang}/about/`, inLanguage: lang, about: orgNode },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: t('nav.work'), item: `${site.url}/${lang}/` },
        { '@type': 'ListItem', position: 2, name: a.heading, item: `${site.url}/${lang}/about/` },
      ],
    },
  ],
};
---

<Base locale={lang} title={a.heading} description={site.description} jsonLd={jsonLd} subpath="about">
  <section class="about-page">
    <div class="padding-global">
      <h1 class="display">{a.heading}</h1>

      <div class="prose container">
        {a.paragraphs.map((p) => <p>{p}</p>)}
      </div>

      <section class="team container">
        <span class="team-label caps">{a.teamHeading}</span>
        <div class="team-people">
          {a.team.map((m) => (
            <div class="team-person">
              <h3>{m.name}</h3>
              <span>{m.role}</span>
            </div>
          ))}
        </div>
        <p class="team-desc">{a.network}</p>
      </section>

      <section class="offices container">
        <span class="offices-label caps">{a.officesHeading}</span>
        <div class="offices-grid">
          {site.offices.map((o) => (
            <div class="office">
              <h4 class="caps">{t(`country.${o.country}`)}</h4>
              <p>
                <strong>{o.name}</strong><br />
                {o.street}<br />
                {o.city}
              </p>
            </div>
          ))}
        </div>
      </section>
    </div>
  </section>
</Base>

<style>
  .about-page {
    padding-top: clamp(6.5rem, 13vh, 9rem);
    padding-bottom: clamp(4rem, 8vw, 7rem);
  }
  .display {
    font-family: var(--font-display);
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    line-height: 0.95;
    text-align: center;
    font-size: clamp(3rem, 12vw, 9rem);
    padding: clamp(1rem, 3vw, 2.5rem) 0 clamp(2.5rem, 5vw, 4rem);
  }

  .prose {
    max-width: 46rem;
  }
  .prose p {
    margin-bottom: 1.2em;
    font-size: clamp(1.05rem, 1.4vw, 1.3rem);
    line-height: 1.6;
    color: rgba(251, 251, 251, 0.92);
  }
  .prose p:first-child {
    font-size: clamp(1.3rem, 2vw, 1.7rem);
    line-height: 1.4;
    color: var(--white);
    margin-bottom: 1.4em;
  }

  .team {
    max-width: 46rem;
    margin-top: clamp(3.5rem, 7vw, 6rem);
    border-top: 1px dashed var(--line);
    padding-top: clamp(2.5rem, 5vw, 4rem);
  }
  .team-label,
  .offices-label {
    display: block;
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    color: var(--grey);
    margin-bottom: 1.75rem;
    font-weight: 700;
  }
  .team-people {
    display: flex;
    flex-wrap: wrap;
    gap: 1.75rem 5rem;
    margin-bottom: 2.5rem;
  }
  .team-person h3 {
    font-size: 1.5rem;
    font-weight: 900;
  }
  .team-person span {
    color: var(--grey);
    font-size: 0.95rem;
  }
  .team-desc {
    font-size: clamp(1rem, 1.2vw, 1.15rem);
    line-height: 1.65;
    color: rgba(251, 251, 251, 0.85);
  }

  .offices {
    max-width: 68rem;
    margin-top: clamp(3.5rem, 7vw, 6rem);
    border-top: 1px dashed var(--line);
    padding-top: clamp(2.5rem, 5vw, 4rem);
  }
  .offices-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
  }
  .office h4 {
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    color: var(--grey);
    margin-bottom: 0.9rem;
    font-weight: 700;
  }
  .office p {
    font-size: 0.98rem;
    line-height: 1.6;
  }
  .office strong {
    font-weight: 700;
  }

  @media (max-width: 820px) {
    .offices-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.75rem;
    }
  }
  @media (max-width: 520px) {
    .offices-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
