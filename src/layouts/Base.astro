---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import CookieBanner from '../components/CookieBanner.astro';
import { site } from '../data/site.js';
import { locales, htmlLang } from '../i18n/ui.js';

const {
  locale = 'en',
  title,
  description = site.description,
  image = '/images/projects/you-and-everything-else-thumb-1280.webp',
  type = 'website',
  jsonLd,
  // path within a locale, e.g. '' for home or 'work/las-heras'
  subpath = '',
  // { player, title } when the page features an embeddable trailer
  video = null,
} = Astro.props;

const pageTitle = title ? `${title} — ${site.name}` : `${site.name} — Film & Series Production, Madrid`;
const canonical = new URL(Astro.url.pathname, site.url).href;
const ogImage = new URL(image, site.url).href;

const altHref = (l) => new URL(`/${l}/${subpath ? subpath + '/' : ''}`, site.url).href;
---

<!doctype html>
<html lang={htmlLang[locale]}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    {locales.map((l) => <link rel="alternate" hreflang={l} href={altHref(l)} />)}
    <link rel="alternate" hreflang="x-default" href={altHref('en')} />

    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#000000" />

    <meta property="og:type" content={type} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content={pageTitle} />
    <meta property="og:locale" content={locale} />
    {locales.filter((l) => l !== locale).map((l) => <meta property="og:locale:alternate" content={l} />)}

    <meta name="twitter:card" content={video ? 'player' : 'summary_large_image'} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    {
      video && (
        <>
          <meta property="og:video" content={video.player} />
          <meta property="og:video:url" content={video.player} />
          <meta property="og:video:secure_url" content={video.player} />
          <meta property="og:video:type" content="text/html" />
          <meta property="og:video:width" content="1280" />
          <meta property="og:video:height" content="720" />
          <meta name="twitter:player" content={video.player} />
          <meta name="twitter:player:width" content="1280" />
          <meta name="twitter:player:height" content="720" />
          <link rel="preconnect" href="https://player.vimeo.com" />
          <link rel="preconnect" href="https://i.vimeocdn.com" />
        </>
      )
    }

    <link rel="preload" href="/fonts/Satoshi-Regular.otf" as="font" type="font/otf" crossorigin />
    <link rel="preload" href="/fonts/Satoshi-Bold.otf" as="font" type="font/otf" crossorigin />
    <link rel="preload" href="/fonts/Galhau_Regular.ttf" as="font" type="font/ttf" crossorigin />

    <link rel="sitemap" href="/sitemap-index.xml" />

    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}

    <script is:inline define:vars={{ gaId: site.analyticsId || '' }}>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      window.gtag = gtag;
      gtag('js', new Date());
      // Consent Mode: everything denied until the visitor accepts.
      gtag('consent', 'default', {
        ad_storage: 'denied',
        ad_user_data: 'denied',
        ad_personalization: 'denied',
        analytics_storage: 'denied',
      });
      window.entropiaLoadGA = function () {
        if (window.__gaLoaded) return;
        if (!gaId || gaId.indexOf('XXXX') !== -1) return;
        window.__gaLoaded = true;
        var s = document.createElement('script');
        s.async = true;
        s.src = 'https://www.googletagmanager.com/gtag/js?id=' + gaId;
        document.head.appendChild(s);
        gtag('consent', 'update', { analytics_storage: 'granted' });
        gtag('config', gaId, { anonymize_ip: true });
      };
      try {
        if (localStorage.getItem('entropia-consent') === 'granted') window.entropiaLoadGA();
      } catch (e) {}
    </script>
  </head>
  <body>
    <Nav locale={locale} subpath={subpath} />
    <main id="main">
      <slot />
    </main>
    <Footer locale={locale} />
    <CookieBanner locale={locale} />
    <script>
      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              e.target.classList.add('is-visible');
              io.unobserve(e.target);
            }
          }
        },
        { rootMargin: '0px 0px -8% 0px', threshold: 0.05 }
      );
      document.querySelectorAll('.reveal').forEach((el) => io.observe(el));
    </script>
  </body>
</html>
