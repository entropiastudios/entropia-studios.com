---
import { site } from '../data/site.js';
import { locales, localeNames, useTranslations } from '../i18n/ui.js';

const { locale = 'en', subpath = '' } = Astro.props;
const t = useTranslations(locale);
const home = `/${locale}/`;

const links = [
  { href: home, label: t('nav.work') },
  { href: `${home}about`, label: t('nav.about') },
  { href: `${home}contact`, label: t('nav.contact') },
];
const langHref = (l) => `/${l}/${subpath ? subpath + '/' : ''}`;
---

<header class="navbar">
  <div class="padding-global">
    <div class="navbar-inner">
      <a href={home} class="brand" aria-label={`${site.name} — home`}>
        <img src="/images/logo.png" alt="" width="26" height="26" />
        <span class="brand-word">{site.name}</span>
      </a>

      <div class="navbar-right">
        <nav aria-label="Primary">
          <ul class="nav-list">
            {links.map((l) => (
              <li><a href={l.href} class="nav-link">{l.label}</a></li>
            ))}
          </ul>
        </nav>
        <div class="lang" aria-label="Language">
          {locales.map((l, i) => (
            <>
              {i > 0 && <span class="lang-sep" aria-hidden="true">/</span>}
              <a href={langHref(l)} class="lang-link" aria-current={l === locale ? 'true' : undefined}>
                {localeNames[l]}
              </a>
            </>
          ))}
        </div>

        <button class="nav-toggle" aria-label="Menu" aria-expanded="false" aria-controls="mobile-menu">
          <span></span><span></span><span></span>
        </button>
      </div>
    </div>
  </div>

  <div class="mobile-menu" id="mobile-menu">
    <div class="padding-global">
      {links.map((l) => (
        <a href={l.href} class="mobile-link">{l.label}</a>
      ))}
    </div>
  </div>
</header>

<script>
  const tgl = document.querySelector('.nav-toggle');
  const menu = document.getElementById('mobile-menu');
  if (tgl && menu) {
    const close = () => {
      tgl.setAttribute('aria-expanded', 'false');
      menu.classList.remove('is-open');
      document.body.style.overflow = '';
    };
    tgl.addEventListener('click', () => {
      const open = tgl.getAttribute('aria-expanded') === 'true';
      if (open) return close();
      tgl.setAttribute('aria-expanded', 'true');
      menu.classList.add('is-open');
      document.body.style.overflow = 'hidden';
    });
    menu.querySelectorAll('a').forEach((a) => a.addEventListener('click', close));
    window.addEventListener('keydown', (e) => e.key === 'Escape' && close());
  }
</script>

<style>
  .navbar {
    position: fixed;
    inset: 0 0 auto;
    z-index: 1000;
    padding-block: 1.1rem;
    background: linear-gradient(to bottom, rgba(0, 0, 0, 0.9), rgba(0, 0, 0, 0));
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }
  .navbar-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-weight: 700;
    font-size: 0.98rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  .brand img {
    width: 24px;
    height: 24px;
  }
  .navbar-right {
    display: flex;
    align-items: center;
    gap: 2rem;
  }
  .nav-list {
    display: flex;
    gap: 1.75rem;
    margin: 0;
  }
  .nav-link {
    font-size: 0.9rem;
    font-weight: 500;
    opacity: 0.8;
    transition: opacity 0.2s var(--ease);
  }
  .nav-link:hover {
    opacity: 1;
  }
  .lang {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.8rem;
    letter-spacing: 0.05em;
  }
  .lang-link {
    opacity: 0.5;
    transition: opacity 0.2s var(--ease);
  }
  .lang-link:hover {
    opacity: 0.85;
  }
  .lang-link[aria-current='true'] {
    opacity: 1;
    color: var(--red);
  }
  .lang-sep {
    opacity: 0.3;
  }

  /* Hamburger toggle + mobile menu (hidden on desktop) */
  .nav-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 30px;
    height: 30px;
    padding: 0;
    background: none;
    border: 0;
    cursor: pointer;
  }
  .nav-toggle span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--white);
    transition: transform 0.25s var(--ease), opacity 0.2s var(--ease);
  }
  .nav-toggle[aria-expanded='true'] span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .nav-toggle[aria-expanded='true'] span:nth-child(2) {
    opacity: 0;
  }
  .nav-toggle[aria-expanded='true'] span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }
  .mobile-menu {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background: rgba(0, 0, 0, 0.97);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    padding-block: 0.5rem 1.25rem;
  }
  .mobile-menu.is-open {
    display: block;
  }
  .mobile-link {
    display: block;
    font-size: 1.35rem;
    font-weight: 600;
    padding: 0.85rem 0;
    border-bottom: 1px dashed var(--line);
  }
  .mobile-link:last-child {
    border-bottom: 0;
  }

  @media (max-width: 768px) {
    .navbar-right {
      gap: 1.1rem;
    }
    .nav-list {
      gap: 1rem;
    }
    .nav-link {
      font-size: 0.82rem;
    }
  }
  @media (max-width: 560px) {
    .nav-list {
      display: none;
    }
    .nav-toggle {
      display: flex;
    }
  }
</style>
