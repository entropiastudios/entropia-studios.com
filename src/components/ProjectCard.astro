---
import { useTranslations } from '../i18n/ui.js';

const { project, locale = 'en', index = 0 } = Astro.props;
const t = useTranslations(locale);
const eager = index < 2;

const category = t(`cat.${project.category}`);
const status = /^\d{4}$/.test(project.status) ? project.status : t(`status.${project.status}`);
---

<a class="card reveal" href={`/${locale}/work/${project.slug}`} aria-label={`${project.title} — ${category}`}>
  <div class="card-media">
    <img
      src={project.thumb}
      srcset={project.thumbSrcset}
      sizes="(max-width: 768px) 100vw, 50vw"
      width={project.thumbW}
      height={project.thumbH}
      alt={`${project.title} — ${category}`}
      loading={eager ? 'eager' : 'lazy'}
      decoding="async"
    />
  </div>
  <div class="card-meta">
    <div class="card-meta-top">
      <span class="card-cat caps">{category}</span>
      <span class="card-year caps">{status}</span>
    </div>
    <span class="card-title caps">{project.title}</span>
  </div>
</a>

<style>
  .card {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    padding-bottom: 1.75rem;
    border-bottom: 1px dashed var(--line);
  }
  .card-media {
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border-radius: 10px;
    background: var(--surface);
  }
  .card-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.8s var(--ease);
  }
  .card:hover .card-media img {
    transform: scale(1.04);
  }
  .card-meta {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .card-meta-top {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    color: var(--grey);
    font-size: 0.85rem;
    letter-spacing: 0.08em;
  }
  .card-title {
    font-weight: 700;
    font-size: clamp(1.15rem, 1.7vw, 1.6rem);
    line-height: 1.15;
    text-decoration: underline;
    text-decoration-color: transparent;
    text-underline-offset: 4px;
    text-decoration-thickness: 2px;
    transition: text-decoration-color 0.3s var(--ease);
  }
  .card:hover .card-title {
    text-decoration-color: currentColor;
  }
</style>
